PORT=4000

# Preferred when using hosted Postgres (for example, Supabase).
DATABASE_URL=
SUPABASE_DB_URL=

DB_HOST=localhost
DB_PORT=5432
DB_NAME=bloom_gis
DB_USER=postgres
DB_PASSWORD=postgres

# For Supabase, set DB_SSL=true. Keep rejectUnauthorized=true unless you have a local TLS/cert issue.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Supabase Storage settings used by POST /api/drafts/submit.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=bloom-uploads
SUPABASE_STORAGE_PREFIX=draft-submissions

CORS_ORIGIN=*
